# ============================================================================
# APME EditorConfig - Consistent coding styles across editors
# ============================================================================
# https://editorconfig.org

root = true

# ============================================================================
# DEFAULT - All files
# ============================================================================

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# ============================================================================
# PYTHON
# ============================================================================

[*.py]
indent_size = 4
max_line_length = 88

[*.pyi]
indent_size = 4

# ============================================================================
# YAML / ANSIBLE
# ============================================================================

[*.{yml,yaml}]
indent_size = 2

# ============================================================================
# JSON
# ============================================================================

[*.json]
indent_size = 2

# ============================================================================
# TOML
# ============================================================================

[*.toml]
indent_size = 4

# ============================================================================
# PROTOBUF
# ============================================================================

[*.proto]
indent_size = 2

# ============================================================================
# REGO (OPA)
# ============================================================================

[*.rego]
indent_size = 4
indent_style = tab

# ============================================================================
# MARKDOWN
# ============================================================================

[*.md]
trim_trailing_whitespace = false
max_line_length = off

# ============================================================================
# SHELL SCRIPTS
# ============================================================================

[*.{sh,bash,zsh}]
indent_size = 2

# ============================================================================
# DOCKER
# ============================================================================

[Dockerfile*]
indent_size = 4

[Containerfile*]
indent_size = 4

# ============================================================================
# MAKEFILES
# ============================================================================

[Makefile]
indent_style = tab
indent_size = 4

[*.mk]
indent_style = tab
indent_size = 4

# ============================================================================
# GIT
# ============================================================================

[.git*]
indent_size = 4

# ============================================================================
# CI/CD
# ============================================================================

[.github/**/*.yml]
indent_size = 2

[.gitlab-ci.yml]
indent_size = 2

# ============================================================================
# WEB (if dashboard)
# ============================================================================

[*.{html,htm}]
indent_size = 2

[*.css]
indent_size = 2

[*.{js,jsx,ts,tsx}]
indent_size = 2

# ============================================================================
# MISC
# ============================================================================

[*.{xml,svg}]
indent_size = 2

[*.sql]
indent_size = 2

# Lock files - don't modify
[{uv.lock,poetry.lock,Pipfile.lock,package-lock.json,yarn.lock}]
indent_size = unset
insert_final_newline = unset
trim_trailing_whitespace = unset
