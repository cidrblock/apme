# ============================================================================
# APME Environment Variables Example
# ============================================================================
#
# Copy this file to .env and fill in actual values.
# NEVER commit .env to version control!
#
# ============================================================================

# ============================================================================
# PRIMARY SERVICE
# ============================================================================

APME_PRIMARY_LISTEN=0.0.0.0:50051

# Validator addresses (within pod, use localhost)
NATIVE_GRPC_ADDRESS=127.0.0.1:50055
OPA_GRPC_ADDRESS=127.0.0.1:50054
ANSIBLE_GRPC_ADDRESS=127.0.0.1:50053
GITLEAKS_GRPC_ADDRESS=127.0.0.1:50056

# Concurrency limits
APME_PRIMARY_MAX_RPCS=16

# ============================================================================
# NATIVE VALIDATOR
# ============================================================================

APME_NATIVE_VALIDATOR_LISTEN=0.0.0.0:50055
APME_NATIVE_MAX_RPCS=32

# ============================================================================
# OPA VALIDATOR
# ============================================================================

APME_OPA_VALIDATOR_LISTEN=0.0.0.0:50054
APME_OPA_MAX_RPCS=32

# OPA internal REST (not typically changed)
# OPA_REST_ADDRESS=localhost:8181

# ============================================================================
# ANSIBLE VALIDATOR
# ============================================================================

APME_ANSIBLE_VALIDATOR_LISTEN=0.0.0.0:50053
APME_ANSIBLE_MAX_RPCS=8
APME_CACHE_ROOT=/cache

# Default ansible-core version if not specified in request
# APME_DEFAULT_ANSIBLE_VERSION=2.18

# ============================================================================
# GITLEAKS VALIDATOR
# ============================================================================

APME_GITLEAKS_VALIDATOR_LISTEN=0.0.0.0:50056
APME_GITLEAKS_MAX_RPCS=16

# ============================================================================
# CACHE MAINTAINER
# ============================================================================

APME_CACHE_MAINTAINER_LISTEN=0.0.0.0:50052
APME_CACHE_ROOT=/cache

# Galaxy server (for collection downloads)
# APME_GALAXY_SERVER=https://galaxy.ansible.com

# GitHub token for org cloning (optional, for private repos)
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# ============================================================================
# CLI (local development)
# ============================================================================

# Primary address for CLI to connect to
# APME_PRIMARY_ADDRESS=127.0.0.1:50051

# OPA mode (podman or local binary)
# OPA_USE_PODMAN=1

# ============================================================================
# LOGGING
# ============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR
APME_LOG_LEVEL=INFO

# Structured logging format: json, console
APME_LOG_FORMAT=console

# ============================================================================
# AI REMEDIATION (Future - DR-005)
# ============================================================================

# LLM provider: none, anthropic, openai, ollama
# APME_LLM_PROVIDER=none

# API keys (if using external providers)
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx
# OPENAI_API_KEY=sk-xxxxxxxxxxxx

# Ollama endpoint (if using local models)
# OLLAMA_HOST=http://localhost:11434

# ============================================================================
# DATABASE (Future - DR-008)
# ============================================================================

# Database URL for scan result persistence
# APME_DATABASE_URL=sqlite:///./apme.db
# APME_DATABASE_URL=postgresql://user:pass@localhost:5432/apme
