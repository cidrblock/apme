[119.853375, "o", "\r\n"]
[120.165369, "o", "- hosts: all\r\n"]
[120.198117, "o", "  become_user: deployer\r\n"]
[120.232767, "o", "  vars:\r\n"]
[120.268054, "o", "    ansible_python_interpreter: /usr/bin/python2.7\r\n"]
[120.301029, "o", "  tasks:\r\n"]
[120.335204, "o", "    - shell: apt-get update && apt-get install -y nginx\r\n"]
[120.367196, "o", "    - name: copy config\r\n"]
[120.399818, "o", "      copy:\r\n"]
[120.432664, "o", "        src: nginx.conf\r\n"]
[120.465312, "o", "        dest: /etc/nginx/nginx.conf\r\n"]
[120.497419, "o", "    - name: greeting\r\n"]
[120.529315, "o", "      command: echo {{ greeting }}\r\n"]
[120.561368, "o", "    - include: tasks/setup.yml\r\n"]
[120.594356, "o", "    - name: install packages\r\n"]
[120.629701, "o", "      yum:\r\n"]
[120.662247, "o", "        name: \"{{ item }}\"\r\n"]
[120.701288, "o", "        state: latest\r\n"]
[120.734444, "o", "      with_items:\r\n"]
[120.766392, "o", "        - vim\r\n"]
[120.799029, "o", "        - curl\r\n"]
[120.832796, "o", "        - wget\r\n"]
[120.865313, "o", "    - name: set permissions\r\n"]
[120.897749, "o", "      file:\r\n"]
[120.930753, "o", "        path: /opt/app\r\n"]
[120.963397, "o", "        mode: 755\r\n"]
[120.996207, "o", "        state: directory\r\n"]
[121.028763, "o", "    - name: run deploy script\r\n"]
[121.060733, "o", "      shell: |\r\n"]
[121.092906, "o", "        cd /opt/app && make build | tee build.log\r\n"]
[121.124829, "o", "    - name: check result\r\n"]
[121.157451, "o", "      shell: cat /var/log/deploy.log\r\n"]
[121.190129, "o", "      ignore_errors: true\r\n"]
[121.223489, "o", "      become: true\r\n"]
[121.257562, "o", "    - name: configure app\r\n"]
[121.290833, "o", "      local_action: template src=app.conf.j2 dest=/etc/app/app.conf\r\n"]
[121.323579, "o", "    - name: wait for restart\r\n"]
[121.356452, "o", "      command: sleep 10\r\n"]
[121.389286, "o", "      when: \"{{ needs_restart }}\"\r\n"]
[121.422289, "o", "    - name: check if empty\r\n"]
[121.455463, "o", "      debug:\r\n"]
[121.487471, "o", "        msg: \"variable is empty\"\r\n"]
[121.519354, "o", "      when: my_var == \"\"\r\n"]
[121.550949, "o", "    - name: set flag\r\n"]
[121.583317, "o", "      set_fact:\r\n"]
[121.615297, "o", "        is_ready: true\r\n"]
[121.64969, "o", "      when: deploy_result == true\r\n"]
[128.193957, "o", "\u001b[H\u001b[2J\u001b[3J"]
[128.21098, "o", "\r\n                                                       \u001b[1;33m╔═════════╗\u001b[0m\r\n"]
[128.211366, "o", "                                                       \u001b[1;33m║\u001b[0m  \u001b[1;37mAfter\u001b[0m  \u001b[1;33m║\u001b[0m\r\n                                                       \u001b[1;33m╚═════════╝\u001b[0m\r\n\r\n"]
