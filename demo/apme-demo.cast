[0.022063, "o", "\u001b[H\u001b[2J\u001b[3J"]
[0.033177, "o", "\r\n                                    \u001b[1;33m╔════════════════════════════════════════════════╗\u001b[0m\r\n                                    \u001b[1;33m║\u001b[0m  \u001b[1;37mAPME — Ansible Policy & Modernization Engine\u001b[0m  \u001b[1;33m║\u001b[0m\r\n                                    \u001b[1;33m╚════════════════════════════════════════════════╝\u001b[0m\r\n\r\n"]
[3.327328, "o", "                            \u001b[1;4mAPME — Ansible Policy & Modernization Engine\u001b[0m                            \r\n\r\nEvery org has \u001b[3mthat\u001b[0m Ansible repo. Written by people who left three jobs ago.                         \r\n\r\n\u001b[1mAPME automates the cleanup.\u001b[0m                                                                         \r\n\r\n\u001b[1m • \u001b[0m90+ rules across 5 validators                                                                    \r\n\u001b[1m • \u001b[0m20+ deterministic auto-fix transforms                                                            \r\n\u001b[1m • \u001b[0mTargets AAP 2.5+ / ansible-core 2.18+                                                            \r\n"]
[9.942438, "o", "\u001b[H\u001b[2J\u001b[3J"]
[9.953868, "o", "\r\n                                                    \u001b[1;33m╔════════════════╗\u001b[0m\r\n                                                    \u001b[1;33m║\u001b[0m  \u001b[1;37mArchitecture\u001b[0m  \u001b[1;33m║\u001b[0m\r\n"]
[9.954073, "o", "                                                    \u001b[1;33m╚════════════════╝\u001b[0m\r\n\r\n"]
[12.305365, "o", "                                            \u001b[1;4mArchitecture\u001b[0m                                            \r\n\r\n                                                                                                    \r\n CLI ──► Primary Orchestrator                                                                       \r\n              │                                                                                     \r\n              ├──► Native Validator   (Python rules)                                                \r\n              ├──► OPA Validator      (Rego policies)                                               \r\n              ├──► Ansible Validator  (ansible-core introspection)                                  \r\n              ├──► Gitleaks Scanner   (secret detection)                                            \r\n              └──► Cache Maintainer   (Galaxy + GitHub)                                             \r\n                                                                                                    \r\n\r\nAll gRPC. All async. All in a Podman pod.                                                           \r\n"]
[18.945811, "o", "\u001b[H\u001b[2J\u001b[3J"]
[18.955256, "o", "\r\n                                               \u001b[1;33m╔═════════════════════════╗\u001b[0m\r\n                                               \u001b[1;33m║\u001b[0m  \u001b[1;37mWhat Does APME Catch?\u001b[0m  \u001b[1;33m║\u001b[0m\r\n                                               \u001b[1;33m╚═════════════════════════╝\u001b[0m\r\n\r\n"]
[21.25341, "o", "                                       \u001b[1;4mWhat Does APME Catch?\u001b[0m                                        \r\n\r\n\u001b[1mL\u001b[0m — Lint: FQCN, modes, task names, free-form, bare vars \u001b[1mM\u001b[0m — Modernize: deprecated loops, bare       \r\nincludes, Python 2 \u001b[1mR\u001b[0m — Risk: shell injection, privilege escalation, insecure downloads \u001b[1mSEC\u001b[0m —        \r\nSecrets: passwords, API keys, tokens (Gitleaks) \u001b[1mP\u001b[0m — Policy: module allow/deny, argument validation  \r\n"]
[27.851838, "o", "\u001b[H\u001b[2J\u001b[3J"]
[27.861473, "o", "\r\n                                               \u001b[1;33m╔═════════════════════════╗\u001b[0m\r\n"]
[27.861707, "o", "                                               \u001b[1;33m║\u001b[0m  \u001b[1;37mThe Terrible Playbook\u001b[0m  \u001b[1;33m║\u001b[0m\r\n                                               \u001b[1;33m╚═════════════════════════╝\u001b[0m\r\n\r\n"]
[29.864214, "o", "\u001b[2;37m  # Every org has one. This is ours.\u001b[0m\r\n\r\n"]
[32.867488, "o", "\u001b[1;32m$ \u001b[0mc"]
[32.912943, "o", "a"]
[32.956564, "o", "t"]
[33.002402, "o", " "]
[33.044622, "o", "/"]
[33.086824, "o", "t"]
[33.128899, "o", "m"]
