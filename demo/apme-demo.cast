[114.036334, "o", "- hosts: all\r\n  become_user: deployer\r\n  vars:\r\n    ansible_python_interpreter: /usr/bin/python2.7\r\n  tasks:\r\n    - shell: apt-get update && apt-get install -y nginx\r\n    - name: copy config\r\n      copy:\r\n        src: nginx.conf\r\n        dest: /etc/nginx/nginx.conf\r\n    - name: greeting\r\n      command: echo {{ greeting }}\r\n    - include: tasks/setup.yml\r\n    - name: install packages\r\n      yum:\r\n        name: \"{{ item }}\"\r\n        state: latest\r\n      with_items:\r\n        - vim\r\n        - curl\r\n        - wget\r\n    - name: set permissions\r\n      file:\r\n        path: /opt/app\r\n        mode: 755\r\n        state: directory\r\n    - name: run deploy script\r\n      shell: |\r\n        cd /opt/app && make build | tee build.log\r\n    - name: check result\r\n      shell: cat /var/log/deploy.log\r\n      ignore_errors: true\r\n      become: true\r\n    - name: configure app\r\n      local_action: template src=app.conf.j2 dest=/etc/app/app.conf\r\n    - name: wait for restart\r\n      command: sleep 10\r\n      when: \"{{ needs_restart }}\"\r\n    - name: check if empty\r\n      debug:\r\n        msg: \"variable is empty\"\r\n      when: my_var == \"\"\r\n    - name: set flag\r\n      set_fact:\r\n        is_ready: true\r\n      when: deploy_result == true\r\n"]
