[33.217073, "o", "/"]
[33.263275, "o", "t"]
[33.305773, "o", "m"]
[33.347324, "o", "p"]
[33.389008, "o", "."]
[33.431205, "o", "0"]
[33.473072, "o", "X"]
[33.515995, "o", "n"]
[33.5615, "o", "z"]
[33.606219, "o", "d"]
[33.649888, "o", "a"]
[33.695195, "o", "f"]
[33.741259, "o", "D"]
[33.78357, "o", "i"]
[33.827525, "o", "f"]
[33.872639, "o", "/"]
[33.917491, "o", "s"]
[33.960808, "o", "i"]
[34.004007, "o", "t"]
[34.047336, "o", "e"]
[34.092893, "o", "."]
[34.1374, "o", "y"]
[34.179515, "o", "m"]
[34.222284, "o", "l"]
[34.267622, "o", "\r\n"]
[34.575996, "o", "- hosts: all\r\n"]
[34.60937, "o", "  become_user: deployer\r\n"]
[34.644122, "o", "  vars:\r\n"]
[34.678773, "o", "    ansible_python_interpreter: /usr/bin/python2.7\r\n"]
[34.711858, "o", "  tasks:\r\n"]
[34.74366, "o", "    - shell: apt-get update && apt-get install -y nginx\r\n"]
[34.775299, "o", "    - name: copy config\r\n"]
[34.807493, "o", "      copy:\r\n"]
[34.842476, "o", "        src: nginx.conf\r\n"]
[34.876492, "o", "        dest: /etc/nginx/nginx.conf\r\n"]
[34.909881, "o", "    - name: greeting\r\n"]
[34.941878, "o", "      command: echo {{ greeting }}\r\n"]
[34.973662, "o", "    - include: tasks/setup.yml\r\n"]
[35.005705, "o", "    - name: install packages\r\n"]
[35.037736, "o", "      yum:\r\n"]
[35.069976, "o", "        name: \"{{ item }}\"\r\n"]
[35.102366, "o", "        state: latest\r\n"]
[35.134792, "o", "      with_items:\r\n"]
[35.167457, "o", "        - vim\r\n"]
[35.199868, "o", "        - curl\r\n"]
[35.232264, "o", "        - wget\r\n"]
[35.264667, "o", "    - name: set permissions\r\n"]
[35.296666, "o", "      file:\r\n"]
[35.328866, "o", "        path: /opt/app\r\n"]
[35.361157, "o", "        mode: 755\r\n"]
[35.393642, "o", "        state: directory\r\n"]
[35.426244, "o", "    - name: run deploy script\r\n"]
[35.45828, "o", "      shell: |\r\n"]
[35.490553, "o", "        cd /opt/app && make build | tee build.log\r\n"]
[35.522652, "o", "    - name: check result\r\n"]
[35.554806, "o", "      shell: cat /var/log/deploy.log\r\n"]
[35.587905, "o", "      ignore_errors: true\r\n"]
[35.623026, "o", "      become: true\r\n"]
[35.658063, "o", "    - name: configure app\r\n"]
[35.690775, "o", "      local_action: template src=app.conf.j2 dest=/etc/app/app.conf\r\n"]
[35.722331, "o", "    - name: wait for restart\r\n"]
[35.754178, "o", "      command: sleep 10\r\n"]
[35.786396, "o", "      when: \"{{ needs_restart }}\"\r\n"]
[35.818691, "o", "    - name: check if empty\r\n"]
[35.851316, "o", "      debug:\r\n"]
[35.884272, "o", "        msg: \"variable is empty\"\r\n"]
[35.917048, "o", "      when: my_var == \"\"\r\n"]
[35.949499, "o", "    - name: set flag\r\n"]
[35.981683, "o", "      set_fact:\r\n"]
[36.013706, "o", "        is_ready: true\r\n"]
[36.045732, "o", "      when: deploy_result == true\r\n"]
[42.581519, "o", "\u001b[H\u001b[2J\u001b[3J"]
