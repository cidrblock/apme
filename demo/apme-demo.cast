[0.019331, "o", "\r\n"]
[3.246299, "o", "                            \u001b[1;4mAPME вҖ” Ansible Policy & Modernization Engine\u001b[0m                            \r\n\r\nEvery org has \u001b[3mthat\u001b[0m Ansible repo. Written by people who left three jobs ago.                         \r\n\r\n\u001b[1mAPME automates the cleanup.\u001b[0m                                                                         \r\n\r\n\u001b[1m вҖў \u001b[0m90+ rules across 5 validators                                                                    \r\n\u001b[1m вҖў \u001b[0m20+ deterministic auto-fix transforms                                                            \r\n\u001b[1m вҖў \u001b[0mTargets AAP 2.5+ / ansible-core 2.18+                                                            \r\n"]
[9.825915, "o", "\u001b[H\u001b[2J\u001b[3J"]
[9.831658, "o", "\r\n                                                    \u001b[1;33mв•”в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•—\u001b[0m\r\n                                                    \u001b[1;33mв•‘\u001b[0m  \u001b[1;37mArchitecture\u001b[0m  \u001b[1;33mв•‘\u001b[0m\r\n"]
[9.831712, "o", "                                                    \u001b[1;33mв•ҡв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•қ\u001b[0m\r\n\r\n"]
[12.231593, "o", "                                            \u001b[1;4mArchitecture\u001b[0m                                            \r\n\r\n                                                                                                    \r\n CLI в”Җв”Җв–ә Primary Orchestrator                                                                       \r\n              в”Ӯ                                                                                     \r\n              в”ңв”Җв”Җв–ә Native Validator   (Python rules)                                                \r\n              в”ңв”Җв”Җв–ә OPA Validator      (Rego policies)                                               \r\n              в”ңв”Җв”Җв–ә Ansible Validator  (ansible-core introspection)                                  \r\n              в”ңв”Җв”Җв–ә Gitleaks Scanner   (secret detection)                                            \r\n              в””в”Җв”Җв–ә Cache Maintainer   (Galaxy + GitHub)                                             \r\n                                                                                                    \r\n\r\nAll gRPC. All async. All in a Podman pod.                                                           \r\n"]
[18.829773, "o", "\u001b[H\u001b[2J\u001b[3J"]
[18.835847, "o", "\r\n                                               \u001b[1;33mв•”в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•—\u001b[0m\r\n                                               \u001b[1;33mв•‘\u001b[0m  \u001b[1;37mWhat Does APME Catch?\u001b[0m  \u001b[1;33mв•‘\u001b[0m\r\n"]
