[131.582744, "o", "\r\n"]
[131.88663, "o", "---\r\n"]
[131.918558, "o", "- hosts: all\r\n"]
[131.951123, "o", "  become_user: deployer\r\n"]
[131.984039, "o", "  vars:\r\n"]
[132.016834, "o", "    ansible_python_interpreter: /usr/bin/python2.7\r\n"]
[132.050193, "o", "  tasks:\r\n"]
[132.083494, "o", "    - ansible.builtin.shell:\r\n"]
[132.116934, "o", "        cmd: apt-get update && apt-get install -y nginx\r\n"]
[132.149684, "o", "      changed_when: false\r\n"]
[132.181856, "o", "\r\n"]
[132.214291, "o", "    - name: Copy config\r\n"]
[132.247354, "o", "      ansible.builtin.copy:\r\n"]
[132.280607, "o", "        src: nginx.conf\r\n"]
[132.313061, "o", "        dest: /etc/nginx/nginx.conf\r\n"]
[132.347645, "o", "        mode: \"0644\"\r\n"]
[132.381362, "o", "\r\n"]
[132.415232, "o", "    - name: Greeting\r\n"]
[132.450644, "o", "      ansible.builtin.command:\r\n"]
[132.483529, "o", "        cmd: echo {{ greeting }}\r\n"]
[132.516621, "o", "      changed_when: false\r\n"]
[132.549529, "o", "\r\n"]
[132.582402, "o", "    - ansible.builtin.include_tasks: tasks/setup.yml\r\n"]
[132.614125, "o", "\r\n"]
[132.648312, "o", "    - name: Install packages\r\n"]
[132.682816, "o", "      yum:\r\n"]
[132.716278, "o", "        name: \"{{ item }}\"\r\n"]
[132.748481, "o", "        state: present\r\n"]
[132.78058, "o", "      loop:\r\n"]
[132.813062, "o", "        - vim\r\n"]
[132.845128, "o", "        - curl\r\n"]
[132.877335, "o", "        - wget\r\n"]
[132.909393, "o", "\r\n"]
[132.941813, "o", "    - name: Set permissions\r\n"]
[132.973754, "o", "      ansible.builtin.file:\r\n"]
[133.006155, "o", "        path: /opt/app\r\n"]
[133.038347, "o", "        mode: \"0755\"\r\n"]
[133.070364, "o", "        state: directory\r\n"]
[133.102953, "o", "\r\n"]
[133.134956, "o", "    - name: Run deploy script\r\n"]
[133.166665, "o", "      ansible.builtin.shell:\r\n"]
[133.200312, "o", "        cmd: |\r\n"]
[133.233576, "o", "          set -o pipefail && cd /opt/app && make build | tee build.log\r\n"]
[133.266378, "o", "      changed_when: false\r\n"]
[133.29946, "o", "\r\n"]
[133.33248, "o", "    - name: Check result\r\n"]
[133.365812, "o", "      ansible.builtin.command:\r\n"]
[133.400691, "o", "        cmd: cat /var/log/deploy.log\r\n"]
[133.433525, "o", "      changed_when: false\r\n"]
[133.465758, "o", "      become: true\r\n"]
[133.497699, "o", "      ignore_errors: true\r\n"]
[133.531206, "o", "      ignore_unreachable: true\r\n"]
[133.562859, "o", "\r\n"]
[133.595462, "o", "    - name: Configure app\r\n"]
[133.627527, "o", "      ansible.builtin.template: src=app.conf.j2 dest=/etc/app/app.conf\r\n"]
[133.659715, "o", "      delegate_to: localhost\r\n"]
[133.692818, "o", "      mode: \"0644\"\r\n"]
[133.726113, "o", "\r\n"]
[133.758115, "o", "    - name: Wait for restart\r\n"]
[133.791084, "o", "      ansible.builtin.command:\r\n"]
[133.823534, "o", "        cmd: sleep 10\r\n"]
[133.855807, "o", "      when: needs_restart\r\n"]
[133.888171, "o", "      changed_when: false\r\n"]
[133.920477, "o", "\r\n"]
[133.952912, "o", "    - name: Check if empty\r\n"]
[133.985327, "o", "      ansible.builtin.debug:\r\n"]
[134.017573, "o", "        msg: variable is empty\r\n"]
[134.050037, "o", "      when: my_var | length == 0\r\n"]
[134.082611, "o", "\r\n"]
[134.115118, "o", "    - name: Set flag\r\n"]
[134.147758, "o", "      ansible.builtin.set_fact:\r\n"]
[134.179997, "o", "        is_ready: true\r\n"]
[134.211465, "o", "      when: deploy_result\r\n"]
[140.749367, "o", "\u001b[H\u001b[2J\u001b[3J"]
[140.760503, "o", "\r\n                                                      \u001b[1;33m╔═══════════╗\u001b[0m\r\n                                                      \u001b[1;33m║\u001b[0m  \u001b[1;37mResults\u001b[0m  \u001b[1;33m║\u001b[0m\r\n"]
[140.760688, "o", "                                                      \u001b[1;33m╚═══════════╝\u001b[0m\r\n\r\n"]
[151.544701, "o", "\r\n  \u001b[1;37mViolations before:  \u001b[1;31m80\u001b[0m\r\n  \u001b[1;37mViolations after:   \u001b[1;32m34\u001b[0m\r\n  \u001b[1;37mAuto-fixed:         \u001b[1;33m46  (57%)\u001b[0m\r\n\r\n  \u001b[2;37mRemaining: 30 AI-candidate, 0 manual-review\u001b[0m\r\n\r\n"]
[155.54699, "o", "\u001b[2;37m  # AI escalation via Abbenay will target the 30 AI-candidate violations.\u001b[0m\r\n\r\n"]
[160.053851, "o", "\u001b[H\u001b[2J\u001b[3J"]
[160.060509, "o", "\r\n                                    \u001b[1;33m╔════════════════════════════════════════════════╗\u001b[0m\r\n                                    \u001b[1;33m║\u001b[0m  \u001b[1;37mAPME — Ansible Policy & Modernization Engine\u001b[0m  \u001b[1;33m║\u001b[0m\r\n                                    \u001b[1;33m╚════════════════════════════════════════════════╝\u001b[0m\r\n\r\n"]
[160.060573, "o", "\r\n\u001b[2;37m  # 90+ rules  |  20+ auto-fix transforms  |  5 validators\u001b[0m\r\n\u001b[2;37m  # One command to scan. One command to fix.\u001b[0m\r\n\r\n"]
[160.060614, "o", "\u001b[2;37m  # github.com/ansible/apme\u001b[0m\r\n\r\n"]
