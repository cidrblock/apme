[124.190472, "o", "---\r\n- hosts: all\r\n  become_user: deployer\r\n  vars:\r\n    ansible_python_interpreter: /usr/bin/python2.7\r\n  tasks:\r\n    - ansible.builtin.shell:\r\n        cmd: apt-get update && apt-get install -y nginx\r\n      changed_when: false\r\n\r\n    - name: Copy config\r\n      ansible.builtin.copy:\r\n        src: nginx.conf\r\n        dest: /etc/nginx/nginx.conf\r\n        mode: \"0644\"\r\n\r\n    - name: Greeting\r\n      ansible.builtin.command:\r\n        cmd: echo {{ greeting }}\r\n      changed_when: false\r\n\r\n    - ansible.builtin.include_tasks: tasks/setup.yml\r\n\r\n    - name: Install packages\r\n      yum:\r\n        name: \"{{ item }}\"\r\n        state: present\r\n      loop:\r\n        - vim\r\n        - curl\r\n        - wget\r\n\r\n    - name: Set permissions\r\n      ansible.builtin.file:\r\n        path: /opt/app\r\n        mode: \"0755\"\r\n        state: directory\r\n\r\n    - name: Run deploy script\r\n      ansible.builtin.shell:\r\n        cmd: |\r\n          set -o pipefail && cd /opt/app && make build | tee build.log\r\n      changed_when: false\r\n\r\n    - name: Check result\r\n      ansible.builtin.command:\r\n        cmd: cat /var/log/deploy.log\r\n      changed_when: false\r\n      become: true\r\n      ignore_errors: true\r\n      ignore_unreachable: true\r\n\r\n    - name: Configure app\r\n      ansible.builtin.template: src=app.conf.j2 dest=/etc/app/app.conf\r\n      delegate_to: localhost\r\n      mode: \"0644\"\r\n\r\n    - name: Wait for restart\r\n      ansible.builtin.command:\r\n        cmd: sleep 10\r\n      when: needs_restart\r\n      changed_when: false\r\n\r\n    - name: Check if empty\r\n      ansible.builtin.debug:\r\n        msg: variable is empty\r\n      when: my_var | length == 0\r\n\r\n    - name: Set flag\r\n      ansible.builtin.set_fact:\r\n        is_ready: true\r\n      when: deploy_result\r\n"]
